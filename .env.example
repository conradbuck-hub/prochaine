# Copy to .env and fill in once Stage 0 (STM developer registration) is complete.

# --- LLM ---
ANTHROPIC_API_KEY=
INTENT_MODEL=claude-haiku-4-5
ANSWER_MODEL=claude-haiku-4-5

# --- STM (bus GTFS-RT + GTFS static / métro frequencies) ---
# Auth: sent as the `apiKey` header (developers.stm.info).
STM_API_KEY=
STM_GTFS_RT_TRIP_UPDATES_URL=
STM_GTFS_RT_VEHICLE_POSITIONS_URL=
STM_GTFS_RT_ALERTS_URL=
STM_GTFS_STATIC_URL=

# --- exo / ARTM (commuter rail: timetable + delays; REM RT may flow through this feed — confirm in Stage 0) ---
# Auth is DIFFERENT from STM's: exo RT now goes through the Chrono developer
# portal (portail-developpeur.chrono-saeiv.com), which authenticates via the
# `Ocp-Apim-Subscription-Key` header, not an `apiKey` header. The old
# opendata.exo.quebec RT endpoints are dead — get the current Trip Updates
# URL from the Chrono portal and put it in EXO_GTFS_RT_TRIP_UPDATES_URL below;
# the URL is env-configurable specifically so this swap needs no code change.
EXO_GTFS_STATIC_URL=
EXO_GTFS_RT_TRIP_UPDATES_URL=
EXO_GTFS_RT_ALERTS_URL=
EXO_SUBSCRIPTION_KEY=

# --- REM (static schedule; RT source TBD per Stage 0) ---
REM_GTFS_STATIC_URL=

# --- BIXI (GBFS) ---
BIXI_GBFS_STATION_STATUS_URL=https://gbfs.velobixi.com/gbfs/en/station_status.json
BIXI_GBFS_STATION_INFORMATION_URL=https://gbfs.velobixi.com/gbfs/en/station_information.json

# --- Weather (Open-Meteo — keyless, free; server/config.js defaults to this URL) ---
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_LAT=45.5019
WEATHER_LON=-73.5674

# --- Server ---
PORT=3000
